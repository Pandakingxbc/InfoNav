<launch>
    <arg name="map_size_x_"/>
    <arg name="map_size_y_"/>

    <arg name="odometry_topic_"/>
    <arg name="sensor_pose_topic_"/>
    <arg name="depth_topic_"/>

    <arg name="cx_"/>
    <arg name="cy_"/>
    <arg name="fx_"/>
    <arg name="fy_"/>

    <!-- VLM Validation -->
    <arg name="vlm_validation_enabled_" default="false"/>

    <!-- main node -->
    <node pkg="exploration_manager" name="exploration_node" type="exploration_node" output="screen">
        <remap from ="/odom_world"    to = "$(arg odometry_topic_)"/>
        <remap from ="/map_ros/pose"  to = "$(arg sensor_pose_topic_)"/>
        <remap from ="/map_ros/depth" to = "$(arg depth_topic_)"/>

        <!-- Mapping -->
        <!-- ray_mode = 0: penetrate ; ray_mode = 1: non-penetrate -->
        <param name="sdf_map/ray_mode" value="0" />
        <param name="sdf_map/resolution" value="0.05" />
        <param name="sdf_map/map_size_x" value="$(arg map_size_x_)" />
        <param name="sdf_map/map_size_y" value="$(arg map_size_y_)" />
        <param name="sdf_map/obstacles_inflation" value="0.18" />
        <param name="sdf_map/local_bound" value="5.0"/>

        <param name="sdf_map/p_hit" value="0.90"/>
        <param name="sdf_map/p_miss" value="0.48"/>
        <param name="sdf_map/p_min" value="0.10"/>
        <param name="sdf_map/p_max" value="0.98"/>
        <param name="sdf_map/p_occ" value="0.80"/>
        <param name="sdf_map/max_ray_length" value="4.99"/>
        <param name="sdf_map/optimistic" value="false" type="bool"/>
        <param name="sdf_map/signed_dist" value="false" type="bool"/>

        <param name="map_ros/cx" value="$(arg cx_)"/>
        <param name="map_ros/cy" value="$(arg cy_)"/>
        <param name="map_ros/fx" value="$(arg fx_)"/>
        <param name="map_ros/fy" value="$(arg fy_)"/>
        <param name="map_ros/depth_filter_maxdist" value="4.99"/>
        <param name="map_ros/depth_filter_mindist" value="0.0"/>
        <param name="map_ros/depth_filter_margin" value="2"/>
        <param name="map_ros/filter_min_height" value="0.28"/>
        <param name="map_ros/filter_max_height" value="1.18"/>
        <param name="map_ros/k_depth_scaling_factor" value="65535.0"/>
        <param name="map_ros/skip_pixel" value="1"/>
        <param name="map_ros/frame_id" value="world"/>
        <param name="map_ros/virtual_ground_height" value="-0.34"/>

        <param name="fsm/is_real_world" value="false" type="bool"/>

        <!-- Exploration manager -->
        <!-- 0: distance 1: value(greedy) 2: value(TSP top-k) 3: distance(TSP all) 4: WTRP(top-k) -->
        <param name="exploration/policy" value="0" type="int"/>
        <param name="exploration/top_k_value" value="20" type="int"/>
        <param name="exploration/tsp_dir" value="$(find lkh_mtsp_solver)/resource" type="string"/>
        <!-- Dual-Value Fusion: V_total = alpha * V_sem + (1-alpha) * V_ig -->
        <param name="exploration/fusion_alpha" value="0" type="double"/>
        <param name="exploration/use_ig_fusion" value="true" type="bool"/>
        <!-- Adaptive Alpha: alpha(t) = alpha_base + (1-alpha_base) * max_fi(V_HSVM(fi)) / tau_conf -->
        <!-- When strong semantic cues detected at frontiers, favor exploitation; otherwise explore -->
        <param name="exploration/use_adaptive_alpha" value="false" type="bool"/>
        <param name="exploration/alpha_base" value="1" type="double"/>
        <param name="exploration/tau_conf" value="0.8" type="double"/>
        <!-- WTRP: Weighted Traveling Repairman Problem (min weighted arrival time) -->
        <param name="exploration/wtrp_temperature" value="0.3" type="double"/>
        <!-- WTRP target hysteresis: only switch target if new cost is better by this ratio -->
        <param name="exploration/wtrp_hysteresis_ratio" value="0.8" type="double"/>
        <param name="exploration/wtrp_max_brute_force" value="10" type="int"/>

        <param name="frontier/cluster_min" value="2" type="int"/>
        <param name="frontier/cluster_size_xy" value="0.65" type="double"/>
        <param name="frontier/min_view_finish_fraction" value="0.2" type="double"/>
        <param name="frontier/min_contain_unknown" value="30" type="int"/>

        <param name="object/min_observation_num" value="2" type="int"/>
        <!-- 0: no_fusion 1: ours_fusion 2: max_fusion-->
        <param name="object/fusion_type" value="1" type="int"/>
        <param name="object/use_observation" value="true" type="bool"/>
        <param name="object/vis_cloud" value="true" type="bool"/>

        <!-- ====== Patience-Aware Navigation (Paper Section 3.5) ====== -->
        <!-- Formula: τ(t, obj) = tau_high - (t/T_max) × (tau_high - tau_low) -->
        <!-- IMPORTANT: These values must match habitat_eval_hm3dv2.yaml patience_nav section! -->
        <param name="object/T_max" value="450" type="int"/>
        <param name="object/min_detection_confidence" value="0.2" type="double"/>
        <!-- Fallback for unknown objects -->
        <param name="object/tau_high" value="0.4" type="double"/>
        <param name="object/tau_low" value="0.2" type="double"/>

        <!-- Target-specific thresholds by object size -->
        <!-- Large: bed, couch, sofa, bathtub, fireplace, gym equipment -->
        <param name="object/threshold/large_high" value="0.85" type="double"/>
        <param name="object/threshold/large_low" value="0.55" type="double"/>
        <!-- Medium-large: tv, tv_monitor, counter, cabinet, shower, seating -->
        <param name="object/threshold/medium_large_high" value="0.85" type="double"/>
        <param name="object/threshold/medium_large_low" value="0.5" type="double"/>
        <!-- Medium: chair, sink, table, nightstand, stool -->
        <param name="object/threshold/medium_high" value="0.75" type="double"/>
        <param name="object/threshold/medium_low" value="0.5" type="double"/>
        <!-- Toilet: separate category for fine-tuning toilet -->  
        <param name="object/threshold/toilet_high" value="0.75" type="double"/>
        <param name="object/threshold/toilet_low" value="0.45" type="double"/>
        <!-- Small: plant, potted plant, pillow, towel, clothes -->
        <param name="object/threshold/small_high" value="0.65" type="double"/>
        <param name="object/threshold/small_low" value="0.4" type="double"/>


        <!-- ====== VLM Validation ====== -->
        <!-- Enable VLM-based object validation before confirming target reached -->
        <param name="vlm_validation/enabled" value="$(arg vlm_validation_enabled_)" type="bool"/>
        <!-- Timeout for VLM service call (seconds) -->
        <param name="vlm_validation/timeout" value="90.0" type="double"/>
        <!-- Number of views for multi-view validation (AND logic: all must confirm) -->
        <param name="vlm_validation/num_views" value="4" type="int"/>
        <!-- Camera horizontal FOV in degrees (used for viewpoint computation) -->
        <param name="vlm_validation/camera_hfov" value="79.0" type="double"/>

        <!-- Perception utils -->
        <param name="perception_utils/left_angle" value="$(eval 30 * 3.1415926 / 180.0)" type="double"/>
        <param name="perception_utils/right_angle" value="$(eval 30 * 3.1415926 / 180.0)" type="double"/>
        <param name="perception_utils/max_dist" value="4.0" type="double"/>
        <param name="perception_utils/vis_dist" value="1.0" type="double"/>

        <!-- path searching -->
        <param name="astar/lambda_heu" value="1.0" type="double"/>
        <param name="astar/resolution_astar" value="0.1" type="double"/>
    </node>

    <!-- VLM Validation Node (only launched when enabled) -->
    <node name="qwen_vlm_validation_node" pkg="plan_env" type="qwen_vlm_validation_node.py" output="screen"
          if="$(arg vlm_validation_enabled_)">
    </node>

    <!-- ATSP solver -->
    <node pkg="lkh_mtsp_solver" name="tsp_solver" type="tsp_node" output="log">
        <param name="exploration/tsp_dir" value="$(find lkh_mtsp_solver)/resource" type="string"/>
    </node>
</launch>